# Copy to .env and fill in values you need. Never commit the real .env file.

# Optional — enables LLM-assisted move parsing, Red Cell polish, and AAR (see backend/llm_client.py, redcell, aar).
# Get a key at https://console.anthropic.com/
#ANTHROPIC_API_KEY=

# Optional — live SRTM terrain via OpenTopography. Without a key, elevation uses data/seed/elevation_seed.json.
# https://portal.opentopography.org/
#OPENTOPO_API_KEY=

# Optional — set to 1 to pull GTD from a public HuggingFace mirror once; else bundled data/seed/gtd_sample.csv is used.
#GTD_USE_HF=0
